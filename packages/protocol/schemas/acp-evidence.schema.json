{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-control-plane.local/schemas/acp-evidence.schema.json",
  "title": "ACP Evidence",
  "type": "object",
  "required": ["evidence_id", "type", "uri"],
  "properties": {
    "evidence_id": { "type": "string", "minLength": 1 },
    "type": {
      "type": "string",
      "enum": ["diff", "test_report", "log", "replay", "trace", "summary"]
    },
    "uri": { "type": "string", "minLength": 1 },
    "hash": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "produced_by_run_id": { "type": "string" }
  },
  "additionalProperties": true
}
