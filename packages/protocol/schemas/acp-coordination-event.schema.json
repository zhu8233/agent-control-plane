{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-control-plane.local/schemas/acp-coordination-event.schema.json",
  "title": "ACP CoordinationEvent",
  "type": "object",
  "required": [
    "coordination_event_id",
    "task_id",
    "event_type",
    "message",
    "created_at",
    "actor"
  ],
  "properties": {
    "coordination_event_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "assignment_id": { "type": "string" },
    "event_type": {
      "type": "string",
      "enum": [
        "assigned",
        "blocked",
        "handoff_requested",
        "evidence_submitted",
        "review_requested",
        "status_changed",
        "other"
      ]
    },
    "message": { "type": "string", "maxLength": 16000 },
    "created_at": { "type": "string", "format": "date-time" },
    "actor": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "enum": ["human", "hermes", "agent"] },
        "agent_profile_id": { "type": "string", "maxLength": 2048 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
